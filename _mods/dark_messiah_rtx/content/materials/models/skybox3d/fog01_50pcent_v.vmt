"UnlitGeneric"
{
	
"$baseTexture"	"models/Skybox3D/Fog01"
"$translucent" 1

"$vertexcolor" 1
"$vertexalpha" 1




"Proxies"
	{
	"TextureScroll"
  		{
		   "texturescrollvar" "$baseTextureTransform"
		   "texturescrollrate" .020
		   "texturescrollangle" 90.00
  		}

	"sine"
		
		{
		"sineperiod" 3
		"sinemin"	.25
		"sinemax"	.25
		"resultvar" "$alpha"
		}


 	}
}
