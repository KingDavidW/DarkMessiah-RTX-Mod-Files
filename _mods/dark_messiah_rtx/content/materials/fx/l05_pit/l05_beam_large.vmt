"Unlittwotexture"
{

	"$basetexture" "FX/L05_pit/L05_beam_large"
	"$texture2" "FX/L05_pit/L07_ray_mask"
	
	"$additive" "1"
	"$translucent" "1"
	"$nocull" "1"
	"$nodecal" 1
	"$model" 1
	
	"$vertexcolor" 1
	"$vertexalpha" 1

	"Proxies"

	{


		"texturescroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" .5
			"texturescrollangle" -90
			
		}
		"sine"
		{
			"resultvar" "$alpha"
			"sineperiod" "4"
			"sinemin" ".3"
			"sinemax" ".4"
			
		}



	}
	
}

